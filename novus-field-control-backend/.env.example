NODE_ENV=production
PORT=4010
APP_URL=https://control.seudominio.com
CORS_ORIGIN=http://localhost:8082
ENABLE_SWAGGER=false

# In Coolify, DO NOT use 127.0.0.1/localhost as DB host.
# Use the internal Postgres hostname/service name from Coolify.
DATABASE_URL=postgresql://postgres:your-db-password@your-postgres-host:5432/novus_field_control?schema=public
DIRECT_URL=postgresql://postgres:your-db-password@your-postgres-host:5432/novus_field_control?schema=public

JWT_ACCESS_SECRET=change-me-control-access-secret
JWT_REFRESH_SECRET=change-me-control-refresh-secret
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=30d

# Optional bootstrap admin on deploy seed
SEED_ADMIN_EMAIL=admin@novusfield.com
SEED_ADMIN_PASSWORD=change-me-strong-admin-password
SEED_ADMIN_NAME=Platform Admin
